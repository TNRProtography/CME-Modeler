# Cloudflare Pages _headers
# Vite outputs hashed filenames for all JS/CSS assets, so it is safe to cache them
# for 1 year with immutable. The HTML entry point must NOT be cached long-term
# so that users always get the latest shell with updated asset hashes.

# Hashed JS/CSS/font assets — immutable, 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static icons and images — 1 week (no content-hash in filenames)
/icons/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Background images
/background-aurora.jpg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/background-solar.jpg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# PWA manifest — short cache so icon/name changes roll out quickly
/manifest.json
  Cache-Control: public, max-age=3600

# Service worker — must never be cached or updates won't reach users
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML entry point — revalidate on every visit
/
  Cache-Control: no-cache
  X-Content-Type-Options: nosniff

/*.html
  Cache-Control: no-cache
  X-Content-Type-Options: nosniff
